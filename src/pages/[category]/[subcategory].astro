---
import Layout from '../../layouts/Layout.astro';
import RepoTable from '../../components/RepoTable.astro';
import { getCategories, categoryColor } from '../../lib/repos';

export async function getStaticPaths() {
  const categories = getCategories();
  const paths = [];

  for (const cat of categories.values()) {
    for (const sub of cat.subcategories.values()) {
      paths.push({
        params: { category: cat.slug, subcategory: sub.slug },
        props: { cat, sub },
      });
    }
  }

  return paths;
}

const { cat, sub } = Astro.props;
const color = categoryColor(cat.name);
const subcategories = Array.from(cat.subcategories.values());
---

<Layout
  title={`${sub.name} — ${cat.name}`}
  description={`${sub.repos.length} repositories in ${sub.name} (${cat.name})`}
>
  <!-- Breadcrumb -->
  <nav class="text-sm text-slate-400 mb-6">
    <a href="/" class="hover:text-slate-600">Home</a>
    <span class="mx-2">/</span>
    <a href={`/${cat.slug}/`} class="hover:text-slate-600">{cat.name}</a>
    <span class="mx-2">/</span>
    <span class="text-slate-700 font-medium">{sub.name}</span>
  </nav>

  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-1">
      <div class={`w-3 h-3 rounded-full ${color.header}`}></div>
      <h1 class="text-2xl font-bold text-slate-900">{sub.name}</h1>
    </div>
    <p class="text-slate-500">
      {sub.repos.length} repositories ·
      <a href={`/${cat.slug}/`} class={`${color.text} hover:underline`}>{cat.name}</a>
    </p>
  </div>

  <!-- Sibling subcategory pills -->
  <div class="mb-8">
    <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">
      All subcategories in {cat.name}
    </h2>
    <div class="flex flex-wrap gap-2">
      {subcategories.map((sibling) => (
        <a
          href={`/${cat.slug}/${sibling.slug}/`}
          class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-sm font-medium transition-colors ${
            sibling.slug === sub.slug ? color.pillActive : color.pill
          }`}
        >
          {sibling.name}
          <span class="text-xs opacity-70">({sibling.repos.length})</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Repos table -->
  <div>
    <h2 class="text-lg font-semibold text-slate-800 mb-4">
      Repositories
      <span class="text-slate-400 font-normal text-base ml-2">— sorted by stars</span>
    </h2>
    <RepoTable repos={sub.repos} tableId={`sub-${sub.slug}`} />
  </div>
</Layout>
