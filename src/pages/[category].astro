---
import Layout from '../layouts/Layout.astro';
import RepoTable from '../components/RepoTable.astro';
import { getCategories, categoryColor } from '../lib/repos';

export async function getStaticPaths() {
  const categories = getCategories();
  return Array.from(categories.values()).map((cat) => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const color = categoryColor(cat.name);
const subcategories = Array.from(cat.subcategories.values());
---

<Layout title={cat.name} description={`${cat.repos.length} repositories in ${cat.name}`}>
  <!-- Breadcrumb -->
  <nav class="text-sm text-slate-400 mb-6">
    <a href="/" class="hover:text-slate-600">Home</a>
    <span class="mx-2">/</span>
    <span class="text-slate-700 font-medium">{cat.name}</span>
  </nav>

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <div class={`w-3 h-3 rounded-full ${color.header}`}></div>
      <h1 class="text-2xl font-bold text-slate-900">{cat.name}</h1>
    </div>
    <p class="text-slate-500">{cat.repos.length} repositories across {subcategories.length} subcategories</p>
  </div>

  <!-- Subcategory pills -->
  <div class="mb-8">
    <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Subcategories</h2>
    <div class="flex flex-wrap gap-2">
      {subcategories.map((sub) => (
        <a
          href={`/${cat.slug}/${sub.slug}/`}
          class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-sm font-medium transition-colors ${color.pill}`}
        >
          {sub.name}
          <span class="text-xs opacity-70">({sub.repos.length})</span>
        </a>
      ))}
    </div>
  </div>

  <!-- All repos table -->
  <div>
    <h2 class="text-lg font-semibold text-slate-800 mb-4">
      All Repositories
      <span class="text-slate-400 font-normal text-base ml-2">— sorted by stars</span>
    </h2>
    <RepoTable repos={cat.repos} tableId={`cat-${cat.slug}`} />
  </div>
</Layout>
