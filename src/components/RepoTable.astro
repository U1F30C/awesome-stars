---
import type { Repo } from '../lib/repos';
import { formatStars } from '../lib/repos';

export interface Props {
  repos: Repo[];
  tableId: string;
}

const { repos, tableId } = Astro.props;

const languageColors: Record<string, string> = {
  TypeScript: 'bg-blue-100 text-blue-800',
  JavaScript: 'bg-yellow-100 text-yellow-800',
  Python: 'bg-green-100 text-green-800',
  Rust: 'bg-orange-100 text-orange-800',
  Go: 'bg-cyan-100 text-cyan-800',
  Java: 'bg-red-100 text-red-800',
  'C++': 'bg-pink-100 text-pink-800',
  C: 'bg-purple-100 text-purple-800',
  Ruby: 'bg-rose-100 text-rose-800',
  Swift: 'bg-orange-100 text-orange-800',
  Kotlin: 'bg-violet-100 text-violet-800',
  Dart: 'bg-teal-100 text-teal-800',
  PHP: 'bg-indigo-100 text-indigo-800',
  Shell: 'bg-slate-100 text-slate-800',
  Scala: 'bg-red-100 text-red-800',
  Elixir: 'bg-purple-100 text-purple-800',
  Haskell: 'bg-indigo-100 text-indigo-800',
  Zig: 'bg-yellow-100 text-yellow-800',
  Nix: 'bg-blue-100 text-blue-800',
  Lua: 'bg-blue-100 text-blue-800',
  GLSL: 'bg-green-100 text-green-800',
  HLSL: 'bg-green-100 text-green-800',
  Svelte: 'bg-orange-100 text-orange-800',
  Vue: 'bg-emerald-100 text-emerald-800',
  MDX: 'bg-yellow-100 text-yellow-800',
  CSS: 'bg-blue-100 text-blue-800',
  HTML: 'bg-orange-100 text-orange-800',
};

function langClass(lang: string): string {
  return languageColors[lang] ?? 'bg-slate-100 text-slate-700';
}
---

<div class="mb-4">
  <input
    type="text"
    id={`search-${tableId}`}
    placeholder="Search repos by name, description, or language..."
    class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-transparent"
  />
</div>

<div class="overflow-x-auto rounded-lg border border-slate-200">
  <table class="min-w-full divide-y divide-slate-200" id={tableId}>
    <thead class="bg-slate-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider w-48">
          Repository
        </th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider w-24">
          Stars
        </th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider w-28">
          Language
        </th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
          Description
        </th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-slate-100">
      {repos.map((repo) => (
        <tr
          class="hover:bg-slate-50 transition-colors"
          data-search={`${repo.name} ${repo.description ?? ''} ${repo.language ?? ''}`.toLowerCase()}
        >
          <td class="px-4 py-3">
            <a
              href={repo.url}
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-slate-900 hover:text-blue-600 transition-colors text-sm"
            >
              {repo.owner}/{repo.name}
            </a>
          </td>
          <td class="px-4 py-3 text-sm text-slate-600 whitespace-nowrap">
            ⭐ {formatStars(repo.stars)}
          </td>
          <td class="px-4 py-3">
            {repo.language ? (
              <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${langClass(repo.language)}`}>
                {repo.language}
              </span>
            ) : (
              <span class="text-slate-400 text-xs">—</span>
            )}
          </td>
          <td class="px-4 py-3 text-sm text-slate-600 max-w-md">
            <span class="line-clamp-2">{repo.description ?? ''}</span>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<p class="mt-2 text-xs text-slate-400" id={`count-${tableId}`}>
  Showing {repos.length} repositories
</p>

<script define:vars={{ tableId }}>
  const input = document.getElementById(`search-${tableId}`);
  const table = document.getElementById(tableId);
  const countEl = document.getElementById(`count-${tableId}`);

  if (input && table && countEl) {
    const rows = Array.from(table.querySelectorAll('tbody tr'));
    const total = rows.length;

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let visible = 0;

      rows.forEach((row) => {
        const text = row.getAttribute('data-search') ?? '';
        const show = !q || text.includes(q);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      countEl.textContent = q
        ? `Showing ${visible} of ${total} repositories`
        : `Showing ${total} repositories`;
    });
  }
</script>
