# GitHub API Configuration
# This file is a template. Copy it to .env and fill in your values.

# GitHub Personal Access Token
# How to create:
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token (classic)"
# 3. Select scope "public_repo" (to read public repos only)
# 4. Copy the token and paste below
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username
# This is the username of the account whose stars you want to fetch
GITHUB_USERNAME=your_github_username
